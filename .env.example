# ============================================================
# ARIA Engine - Environment Variables
# ============================================================
# 이 파일을 .env로 복사한 후 실제 키 값을 입력하세요
# cp .env.example .env

# === LLM Provider API Keys ===
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GOOGLE_API_KEY=xxxxx
DEEPSEEK_API_KEY=xxxxx

# === Default LLM Configuration ===
ARIA_DEFAULT_MODEL=claude-sonnet-4-20250514
ARIA_FALLBACK_MODEL=gpt-4o
ARIA_CHEAP_MODEL=deepseek/deepseek-chat
ARIA_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# === Qdrant Vector Database ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
# For Qdrant Cloud: QDRANT_URL=https://xxx.qdrant.io

# === API Server ===
ARIA_HOST=0.0.0.0
ARIA_PORT=8100
ARIA_ENV=development
ARIA_LOG_LEVEL=INFO
ARIA_API_KEY=aria-dev-key-change-me
ARIA_AUTH_DISABLED=false

# === Rate Limiting ===
ARIA_RATE_LIMIT_PER_MINUTE=60
ARIA_RATE_LIMIT_BURST=10
ARIA_MAX_TOKENS_PER_REQUEST=4096

# === Cost Control (KillSwitch) ===
ARIA_DAILY_COST_LIMIT_USD=10.0
ARIA_MONTHLY_COST_LIMIT_USD=300.0

# === Notion Integration ===
ARIA_NOTION_TOKEN=ntn_xxxxx
# ARIA_NOTION_API_VERSION=2022-06-28
# ARIA_NOTION_REQUEST_TIMEOUT=30

# === Event Collection ===
# ARIA_EVENT_BASE_PATH=./events
# ARIA_EVENT_MAX_BUFFER_SIZE=1000
# ARIA_EVENT_RETENTION_DAYS=30

# === Proactive Alerts ===
# ARIA_ALERT_ENABLED=true
# ARIA_ALERT_COST_WARNING_THRESHOLD=0.7
# ARIA_ALERT_COST_CRITICAL_THRESHOLD=0.9
# ARIA_ALERT_CONFIDENCE_THRESHOLD=0.3
# ARIA_ALERT_CONSECUTIVE_ERROR_THRESHOLD=3
